<?xml version="1.0" encoding="windows-1251"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="UniversalCorrectionDocument">
    <xs:complexType>
      <xs:all>
        <xs:element minOccurs="0" name="MetaData">
          <xs:complexType>
            <xs:sequence>
              <xs:element maxOccurs="unbounded" default="0" name="IncludeIdentificationNumbers">
                <xs:annotation>
                  <xs:documentation>Типы товаров, подлежащих маркировке (используется для корректного заполнения данных о маркировке в ИдФайл)</xs:documentation>
                  <xs:documentation>0 - товары, подлежащие маркировке (значение по умолчанию)</xs:documentation>
                  <xs:documentation>1 - алкогольная продукция, подлежащая маркировке</xs:documentation>
                  <xs:documentation>2 - табачная продукция, сырье, никотинсодержащая продукция и никотиновое сырье</xs:documentation>
                  <xs:documentation>На основании переданных типов будут сформированы соответствующие признаки в ИдФайл о наличии в документе товаров, подлежащих маркировке</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                  <xs:restriction base="xs:integer">
                    <xs:totalDigits value="3" />
                  </xs:restriction>
                </xs:simpleType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="Invoices">
          <xs:complexType>
            <xs:sequence>
              <xs:element maxOccurs="unbounded" name="Invoice" type="InvoiceForCorrectionInfo">
                <xs:annotation>
                  <xs:documentation>СчФ - счет-фактура (первичный документ), к которому составлен корректировочный счет-фактура</xs:documentation>
                </xs:annotation>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="Seller" type="ExtendedOrganizationInfoUtd970">
          <xs:annotation>
            <xs:documentation>СвПрод - продавец</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="Buyer" type="ExtendedOrganizationInfoUtd970">
          <xs:annotation>
            <xs:documentation>СвПокуп - покупатель</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element minOccurs="0" name="Table" type="InvoiceCorrectionTable">
          <xs:annotation>
            <xs:documentation>ТаблКСчФ - сведения таблицы корректировочного счета-фактуры</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element minOccurs="0" name="EventContent" type="EventContent">
          <xs:annotation>
            <xs:documentation>СодФХЖ3 - Содержание факта хозяйственной жизни 3 - сведения о факте согласования (уведомления)</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element minOccurs="0" name="AdditionalInfoId" type="AdditionalInfoId">
          <xs:annotation>
            <xs:documentation>ИнфПолФХЖ1 - информационное поле документа</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="Signers" type="Signers">
          <xs:annotation>
            <xs:documentation>Подписант - подписант</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element minOccurs="0" name="CommitmentTypes">
          <xs:annotation>
            <xs:documentation>ВидОбяз - виды обязательств</xs:documentation>
          </xs:annotation>
          <xs:complexType>
            <xs:sequence>
              <xs:element maxOccurs="unbounded" name="CommitmentType">
                <xs:annotation>
                  <xs:documentation>ВидОбяз - вид обязательства</xs:documentation>
                </xs:annotation>
                <xs:complexType>
                  <xs:attribute name="CommitmentTypeCode" type="string255">
                    <xs:annotation>
                      <xs:documentation>КодВидОбяз - код вида обязательств</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                  <xs:attribute name="CommitmentTypeName" type="string255">
                    <xs:annotation>
                      <xs:documentation>НаимВидОбяз - наименование вида обязательств</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element minOccurs="0" name="SellerInfoCircumPublicProc">
          <xs:annotation>
            <xs:documentation>ИнфПродЗаГоскКазн - информация продавца об обстоятельствах закупок для государственных и муниципальных нужд</xs:documentation>
          </xs:annotation>
          <xs:complexType>
            <xs:attribute name="DateStateContract" type="date" use="required">
              <xs:annotation>
                <xs:documentation>ДатаГосКонт - дата государственного контракта</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="NumberStateContract" type="string100" use="required">
              <xs:annotation>
                <xs:documentation>НомерГосКонт - номер государственного контракта</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="PersonalAccountSeller" type="string11f">
              <xs:annotation>
                <xs:documentation>ЛицСчетПрод - номер лицевого счета продавца</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="SellerBudgetClassCode" type="string20f">
              <xs:annotation>
                <xs:documentation>КодПродБюджКласс - код бюджетной классификации продавца</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="SellerTargetCode" type="string20f">
              <xs:annotation>
                <xs:documentation>КодЦелиПрод - код цели продавца</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="SellerTreasuryCode" type="string4">
              <xs:annotation>
                <xs:documentation>КодКазначПрод - код территориального органа Федерального казначейства продавца</xs:documentation>
              </xs:annotation>
            </xs:attribute>
            <xs:attribute name="SellerTreasuryName" type="string2000">
              <xs:annotation>
                <xs:documentation>НаимКазначПрод - наименование территориального органа Федерального казначейства продавца</xs:documentation>
              </xs:annotation>
            </xs:attribute>
          </xs:complexType>
        </xs:element>
        <xs:element minOccurs="0" name="DocumentCreatorBase" type="DocumentRequisitesType">
          <xs:annotation>
            <xs:documentation>ОснДоверОргОформ - Основание, по которому экономический субъект формирует и подписывает файл обмена</xs:documentation>
          </xs:annotation>
        </xs:element>
      </xs:all>
      <xs:attribute name="Function" use="required">
        <xs:annotation>
          <xs:documentation>Функция - функция документа</xs:documentation>
          <xs:documentation>
						КСЧФ - корректировочный счет-фактура, применяемый при расчетах по налогу на добавленную стоимость;
						КСЧФДИС - корректировочный счет-фактура, применяемый при расчетах по налогу на добавленную стоимость, 
						и документ, подтверждающий согласие (факт уведомления) покупателя на изменение стоимости отгруженных товаров (выполненных работ, оказанных услуг), переданных имущественных прав;
						ДИС - документ, подтверждающий согласие (факт уведомления) покупателя на изменение стоимости отгруженных товаров (выполненных работ, оказанных услуг), переданных имущественных прав;
						СвИСРК - документ, включающий корректировочные сведения о факте реализации комиссионером (агентом, действующим от собственного имени) товаров комитента (принципала);
						СвИСЗК - документ, включающий корректировочные сведения о факте закупки комиссионером (агентом, действующим от собственного имени) товаров для комитента (принципала)
					</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="3" />
            <xs:maxLength value="7" />
            <xs:enumeration value="КСЧФ" />
            <xs:enumeration value="КСЧФДИС" />
            <xs:enumeration value="ДИС" />
            <xs:enumeration value="СвИСРК" />
            <xs:enumeration value="СвИСЗК" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="DocumentDate" type="date" use="required">
        <xs:annotation>
          <xs:documentation>ДатаДок - дата УКД</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="DocumentNumber" type="string1000" use="required">
        <xs:annotation>
          <xs:documentation>НомерДок - номер УКД</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="Currency" type="okv" use="required">
        <xs:annotation>
          <xs:documentation>КодОКВ - валюта (код)</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="CurrencyRate" type="decimal10f4">
        <xs:annotation>
          <xs:documentation>КурсВал - курс валюты</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="DocumentName" type="string255">
        <xs:annotation>
          <xs:documentation>НаимДокОпр - Наименование документа, определенное организацией (согласованное сторонами сделки)</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="DocumentCreator" type="string1000">
        <xs:annotation>
          <xs:documentation>НаимЭконСубОформ - наименование экономического субъекта-оформителя файла обмена</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="Uid" type="string1000">
        <xs:annotation>
          <xs:documentation>УИД - уникальный идентификатор документа</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="ApprovedStructureAdditionalInfoFields" type="string14f">
        <xs:annotation>
          <xs:documentation>СоглСтрДопИнф - Информация о наличии согласованной структуры дополнительных информационных полей</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="CorrectionRevisionDate" type="date">
        <xs:annotation>
          <xs:documentation>ДатаИспрКСчФ - дата исправления, обязательна если формируется исправление</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="CorrectionRevisionNumber" type="CommonRevisionNumber">
        <xs:annotation>
          <xs:documentation>НомИспрКСчФ - номер исправления, обязателен если формируется исправление</xs:documentation>
        </xs:annotation>
      </xs:attribute>
      <xs:attribute name="GovernmentContractInfo">
        <xs:annotation>
          <xs:documentation>ИдГосКон - идентификатор государственного контракта</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="20" />
            <xs:maxLength value="25" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="CircumFormat">
        <xs:annotation>
          <xs:documentation>СпОбстФКСЧФ/СпОбстФКСЧФДИС/СпОбстФДИС - специальные обстоятельства формирования документа</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="1" />
            <xs:maxLength value="5" />
            <xs:pattern value="[0-9]{1}" />
            <xs:pattern value="[0-9]{5}" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="SenderFnsParticipantId">
        <xs:annotation>
          <xs:documentation>Идентификатор участника ЭДО</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="4" />
            <xs:maxLength value="46" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="RecipientFnsParticipantId">
        <xs:annotation>
          <xs:documentation>Идентификатор участника ЭДО</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="4" />
            <xs:maxLength value="46" />
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:complexType name="InvoiceForCorrectionInfo">
    <xs:sequence>
      <xs:element minOccurs="0" maxOccurs="unbounded" name="Revision">
        <xs:annotation>
          <xs:documentation>ИспрСчФ - с учетом исправления счета-фактуры</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:attribute name="Date" type="date" use="required">
            <xs:annotation>
              <xs:documentation>ДатаИспрСчФ - дата исправления счета-фактуры</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="Number" type="CommonRevisionNumber" use="required">
            <xs:annotation>
              <xs:documentation>НомИспрСчФ - номер исправления счета-фактуры</xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="Date" type="date" use="required">
      <xs:annotation>
        <xs:documentation>ДатаСчФ - дата счета-фактуры</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="Number" type="string1000" use="required">
      <xs:annotation>
        <xs:documentation>НомерСчФ - номер счета-фактуры</xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>
  <xs:complexType name="InvoiceCorrectionTable">
    <xs:all>
      <xs:element name="Items">
        <xs:complexType>
          <xs:sequence>
            <xs:element maxOccurs="unbounded" name="Item" type="InvoiceCorrectionItem">
              <xs:annotation>
                <xs:documentation>СведТов - Сведения об отгруженных товарах (о выполненных работах, оказанных услугах), переданных имущественных правах</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element minOccurs="0" name="TotalsInc" type="InvoiceTotals">
        <xs:annotation>
          <xs:documentation>ВсегоУвел - суммы к увеличению</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element minOccurs="0" name="TotalsDec" type="InvoiceTotals">
        <xs:annotation>
          <xs:documentation>ВсегоУм - суммы к уменьшению</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:all>
  </xs:complexType>
  <xs:complexType name="InvoiceTotals">
    <xs:attribute name="SubtotalWithVatExcluded" type="decimal19f2" use="required">
      <xs:annotation>
        <xs:documentation>СтТовБезНДСВсего - итого стоимость без НДС</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="Subtotal" type="decimal19f2">
      <xs:annotation>
        <xs:documentation>СтТовУчНалВсего - итого стоимость с учетом НДС</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="Vat" type="decimal19f2">
      <xs:annotation>
        <xs:documentation>СумНДС - итоговая сумма налога</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute default="false" name="WithoutVat">
      <xs:annotation>
        <xs:documentation>БезНДС - указывается, если для итоговой суммы налога нет НДС</xs:documentation>
      </xs:annotation>
      <xs:simpleType>
        <xs:restriction base="xs:string">
          <xs:enumeration value="true" />
          <xs:enumeration value="false" />
        </xs:restriction>
      </xs:simpleType>
    </xs:attribute>
  </xs:complexType>
  <xs:complexType name="InvoiceCorrectionItem">
    <xs:all>
      <xs:element minOccurs="0" name="Quantity">
        <xs:annotation>
          <xs:documentation>КолТов - количество товара</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:attribute name="OriginalValue" type="decimal26f11">
            <xs:annotation>
              <xs:documentation>КолТовДо - количество товара до изменения</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="CorrectedValue" type="decimal26f11">
            <xs:annotation>
              <xs:documentation>КолТовПосле - количество товара после изменения</xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:complexType>
      </xs:element>
      <xs:element minOccurs="0" name="Price">
        <xs:annotation>
          <xs:documentation>ЦенаТов - цена товара</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:attribute name="OriginalValue" type="decimal26f11">
            <xs:annotation>
              <xs:documentation>ЦенаТовДо - цена товара до изменения</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="CorrectedValue" type="decimal26f11">
            <xs:annotation>
              <xs:documentation>ЦенаТовПосле - цена товара после изменения</xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:complexType>
      </xs:element>
      <xs:element minOccurs="0" name="SubtotalWithVatExcluded">
        <xs:annotation>
          <xs:documentation>СтТовБезНДС - стоимость без учета налога</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:choice minOccurs="0">
            <xs:element name="AmountsInc" type="decimal19f2">
              <xs:annotation>
                <xs:documentation>СтоимУвел - увеличение стоимости</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="AmountsDec" type="decimal19f2">
              <xs:annotation>
                <xs:documentation>СтоимУм - уменьшение стоимости</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:choice>
          <xs:attribute name="OriginalValue" type="decimal19f2">
            <xs:annotation>
              <xs:documentation>СтоимДоИзм - стоимость до изменения</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="CorrectedValue" type="decimal19f2">
            <xs:annotation>
              <xs:documentation>СтоимПослеИзм - стоимость после изменения</xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:complexType>
      </xs:element>
      <xs:element minOccurs="0" name="Excise">
        <xs:annotation>
          <xs:documentation>Акциз - акциз</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:choice minOccurs="0">
            <xs:element name="AmountsInc" type="decimal19f2">
              <xs:annotation>
                <xs:documentation>АкцизРазн/СумУвел - увеличение акциза</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="AmountsDec" type="decimal19f2">
              <xs:annotation>
                <xs:documentation>АкцизРазн/СумУм - уменьшение акциза</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:choice>
          <xs:attribute name="OriginalValue" type="decimal19f2">
            <xs:annotation>
              <xs:documentation>АкцизДо - акциз до изменения</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="CorrectedValue" type="decimal19f2">
            <xs:annotation>
              <xs:documentation>АкцизПосле - акциз после изменения</xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:complexType>
      </xs:element>
      <xs:element minOccurs="0" name="Vat">
        <xs:annotation>
          <xs:documentation>СумНал - сумма налога</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:choice minOccurs="0">
            <xs:element name="AmountsInc" type="decimal19f2">
              <xs:annotation>
                <xs:documentation>СумУвел - увеличение суммы налога</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="AmountsDec" type="decimal19f2">
              <xs:annotation>
                <xs:documentation>СумУм - уменьшение суммы налога</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:choice>
          <xs:attribute name="OriginalValue" type="decimal19f2">
            <xs:annotation>
              <xs:documentation>СумНалДо - сумма налога до изменения</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="CorrectedValue" type="decimal19f2">
            <xs:annotation>
              <xs:documentation>СумНалПосле - сумма налога после изменения</xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:complexType>
      </xs:element>
      <xs:element minOccurs="0" name="WithoutVat">
        <xs:annotation>
          <xs:documentation>БезНДС - если заполнено, формирует элемент БезНДС; игнорирует заполненные значения в элементе Vat</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:attribute name="OriginalValue">
            <xs:annotation>
              <xs:documentation>СтоимДоИзм - без НДС до изменения</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:string">
                <xs:enumeration value="true" />
              </xs:restriction>
            </xs:simpleType>
          </xs:attribute>
          <xs:attribute name="CorrectedValue">
            <xs:annotation>
              <xs:documentation>СтоимПослеИзм - без НДС после изменения</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="xs:string">
                <xs:enumeration value="true" />
              </xs:restriction>
            </xs:simpleType>
          </xs:attribute>
        </xs:complexType>
      </xs:element>
      <xs:element minOccurs="0" name="Subtotal">
        <xs:annotation>
          <xs:documentation>СтТовУчНал - стоимость с учетом налога</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:choice minOccurs="0">
            <xs:element name="AmountsInc" type="decimal19f2">
              <xs:annotation>
